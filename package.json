{
  "name": "emota",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "verify": "node scripts/verify-stack.mjs",
    "tunnel": "node scripts/run-quick-tunnel.mjs",
    "live": "concurrently -k -n server,tunnel -c blue,magenta \"npm run server\" \"node scripts/run-quick-tunnel.mjs\"",
    "live:build": "npm run build && npm run live",
    "live:dev": "concurrently -k -n server,vite,tunnel -c blue,green,magenta \"npm run server\" \"npm run dev\" \"node scripts/run-quick-tunnel.mjs\"",
    "dev:stack": "npm run live:dev",
    "test:stress": "playwright test tests/stress/instances.spec.ts -g \"gameplay\"",
    "test:stress:hammer": "playwright test tests/stress/instances.spec.ts -g \"hammer:\"",
    "test:stress:event": "playwright test tests/stress/instances.spec.ts -g \"event:\"",
    "bigboard:simulate": "node scripts/trail-bots.mjs --origin=http://127.0.0.1:3333 --count=30",
    "bigboard:simulate:fast": "node scripts/trail-bots.mjs --origin=http://127.0.0.1:3333 --count=30 --interval-ms=650",
    "trail:admin:purge-sim": "node scripts/trail-admin-purge.mjs",
    "trail:bots": "node scripts/trail-bots.mjs",
    "trail:bots:local": "node scripts/trail-bots.mjs --origin=http://127.0.0.1:3333"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
